[gd_scene load_steps=8 format=3 uid="uid://ckxeyqjfr2mdx"]

[sub_resource type="GDScript" id="GDScript_v62h7"]
script/source = "extends CharacterBody2D

var gravity = ProjectSettings.get_setting(\"physics/2d/default_gravity\")

enum State {NEUTRAL, JUMPING, FALLING, ROLLING}
const STATE_NAMES = [\"Neutral\", \"Jumping\", \"Falling\", \"Rolling\"]

var current_state = State.NEUTRAL

@export var max_velocity = Vector2(1000, 1000)
@export var move_speed = Vector2(400, 500)
@export var fast_fall = 0
@export var slow_fall = 0
@export var max_jump_time = 0.2
@export var min_jump_time = 0.05

@export var roll_speed = 800

var jump_time = 0

func _process(delta: float) -> void:
	match current_state:
		State.NEUTRAL: 
			modulate = Color(\"FFA800\")
		State.JUMPING:
			modulate = Color(\"C1E1C1\")
		State.FALLING:
			modulate = Color(\"E1C1E1\")
		State.ROLLING:
			modulate = Color(\"C1D1E1\")

func _physics_process(delta: float) -> void:
	velocity.y += gravity * delta

	if current_state == State.JUMPING:
		if Input.is_action_pressed(\"jump\") or max_jump_time - jump_time < min_jump_time:
			if jump_time <= 0:
				if velocity.y >= 0:
					current_state = State.FALLING
			else:
				jump_time -= delta
				velocity.y = -move_speed.y
		else:
			velocity.y = 0
			current_state = State.FALLING
		if is_on_floor():
			current_state = State.NEUTRAL
	elif current_state == State.FALLING:
		if Input.is_action_pressed(\"down\"):
			velocity.y += fast_fall
		if is_on_floor():
			current_state = State.NEUTRAL
	
	if BufferedInput.is_action_just_pressed(\"jump\") and is_on_floor():
		velocity.y = -move_speed.y
		current_state = State.JUMPING
		jump_time = max_jump_time
	
	var horiz_input = -int(Input.is_action_pressed(\"left\")) + int(Input.is_action_pressed(\"right\"))
	velocity.x = horiz_input*move_speed.x
	
	velocity.x = clamp(velocity.x, -max_velocity.x, max_velocity.x)
	velocity.y = clamp(velocity.y, -max_velocity.y, max_velocity.y)
	move_and_slide()
"

